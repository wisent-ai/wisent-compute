# wisent-compute Azure provider activation env.
# Drop a copy at ~/.config/wisent/azure.env on the mac mini coordinator
# OR add these to the LaunchAgent plist EnvironmentVariables block (when
# install_macos_coordinator.sh is refactored under the line cap).
#
# The provider constructor in wisent_compute/providers/azure.py raises if
# AZURE_SUBSCRIPTION_ID is empty. Everything else has a default in
# wisent_compute/config.py that matches what was provisioned 2026-05-12:
#   RG  = wisent-compute (in eastus)
#   vnets = wisent-compute-vnet-{eastus,westus2,westus3}
#   NSGs  = wisent-compute-nsg-{eastus,westus2,westus3}
# The per-region -{location} suffix is appended automatically by the
# refactored providers/azure_helpers/network.py module.

AZURE_SUBSCRIPTION_ID=9ae7cfa4-93e4-44f6-8f4d-5cea670e22bd
WC_PROVIDERS=gcp,azure
AZURE_RESOURCE_GROUP=wisent-compute
AZURE_LOCATIONS=eastus,westus2,westus3

# Public key for the agent VM cloud-init. Generated at
# ~/.weles/azure_vm_key on the operator workstation 2026-05-12.
# Paste the contents of azure_vm_key.pub here.
AZURE_SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIINBUaUoYAEF2BpuC7poLDvdL1ReWvz8/Su+80tdDQuZ wisent-compute-azure-agent"

# Optional: storage backend toggle. Default keeps the GCS queue intact;
# set to "azure" to route JobStorage at an Azure Blob container instead.
# WC_STORAGE_BACKEND=gcs
# WC_AZURE_STORAGE_ACCOUNT=
# WC_AZURE_CONTAINER=wisent-compute
